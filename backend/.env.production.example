# ExamGuard Production Environment Configuration
# Copy this file to .env.production and update with your production values

# ================================
# DATABASE CONFIGURATION
# ================================

# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# Replace with your actual MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://examguard-admin:YOUR_PASSWORD@examguard-cluster.xxxxx.mongodb.net/examguard?retryWrites=true&w=majority

# ================================
# JWT AUTHENTICATION
# ================================

# JWT Secret Key (MUST be at least 32 characters for production)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secure-jwt-secret-key-for-production-at-least-32-characters

# JWT Token Expiration
JWT_EXPIRE=7d

# ================================
# SERVER CONFIGURATION
# ================================

# Server Port (usually set by hosting platform)
PORT=5000

# Environment
NODE_ENV=production

# ================================
# CORS CONFIGURATION
# ================================

# Frontend URL for CORS (your deployed frontend domain)
FRONTEND_URL=https://your-examguard-frontend.vercel.app

# ================================
# ADMIN USER CONFIGURATION
# ================================

# Default admin user email (created during migration)
ADMIN_EMAIL=admin@yourdomain.com

# Default admin password (change after first login)
# If not set, a default password will be generated
ADMIN_PASSWORD=YourSecureAdminPassword2024!

# ================================
# LOGGING CONFIGURATION
# ================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# ================================
# SECURITY CONFIGURATION
# ================================

# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_MAX=100

# Request timeout (milliseconds)
REQUEST_TIMEOUT=30000

# ================================
# MONITORING CONFIGURATION
# ================================

# Health check interval (milliseconds)
HEALTH_CHECK_INTERVAL=30000

# Enable metrics collection
ENABLE_METRICS=true

# ================================
# BACKUP CONFIGURATION
# ================================

# Maximum number of backups to keep
MAX_BACKUPS=7

# Backup schedule (for automated backups)
BACKUP_SCHEDULE=0 2 * * * # Daily at 2 AM

# ================================
# DEPLOYMENT PLATFORM SPECIFIC
# ================================

# For Render.com - these are usually set automatically
# RENDER=true
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com
# RENDER_EXTERNAL_URL=https://your-app.onrender.com

# For Railway - these are usually set automatically
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app

# For Heroku - these are usually set automatically
# HEROKU_APP_NAME=your-examguard-api
# HEROKU_SLUG_COMMIT=commit-hash

# ================================
# OPTIONAL CONFIGURATIONS
# ================================

# Database connection pool settings (override defaults)
# DB_MAX_POOL_SIZE=20
# DB_MIN_POOL_SIZE=5

# Compression settings
# COMPRESSION_LEVEL=6
# COMPRESSION_THRESHOLD=1024

# Cache settings
# CACHE_MAX_AGE=3600

# ================================
# DANGER ZONE - USE WITH CAUTION
# ================================

# Database reset confirmation (DANGER: deletes all data)
# CONFIRM_RESET=YES_DELETE_ALL_DATA

# Database restore confirmation
# CONFIRM_RESTORE=YES_RESTORE_DATABASE