{
     "name": "examguard-backend",
     "version": "1.0.0",
     "description": "ExamGuard Backend API - Express.js with MongoDB",
     "main": "server.js",
     "scripts": {
          "start": "node server.js",
          "dev": "nodemon server.js",
          "test": "jest",
          "test:watch": "jest --watch",
          "test:e2e": "node tests/e2e/testRunner.js",
          "test:e2e:workflows": "node tests/e2e/testRunner.js workflows",
          "test:e2e:anticheating": "node tests/e2e/testRunner.js anticheating",
          "test:e2e:lifecycle": "node tests/e2e/testRunner.js lifecycle",
          "test:system": "npm run test:e2e",
          "db:validate": "node scripts/validate-database.js",
          "db:migrate": "node scripts/migrate-database.js",
          "db:rollback": "node scripts/migrate-database.js rollback",
          "db:reset": "node scripts/migrate-database.js reset",
          "db:backup": "node scripts/backup-database.js backup",
          "db:restore": "node scripts/backup-database.js restore",
          "db:monitor": "node scripts/backup-database.js monitor",
          "db:optimize": "node scripts/optimize-database.js",
          "production:validate": "node -e \"require('./config/production').validateProductionReadiness()\"",
          "production:deploy": "node scripts/deploy-production.js",
          "production:setup": "npm run production:validate && npm run production:deploy"
     },
     "dependencies": {
          "axios": "^1.13.6",
          "bcryptjs": "^2.4.3",
          "cors": "^2.8.5",
          "dotenv": "^16.3.1",
          "express": "^4.18.2",
          "express-rate-limit": "^7.1.5",
          "express-validator": "^7.0.1",
          "helmet": "^7.1.0",
          "jsonwebtoken": "^9.0.2",
          "mongoose": "^7.6.3",
          "node-cache": "^5.1.2"
     },
     "devDependencies": {
          "jest": "^29.7.0",
          "mongodb-memory-server": "^9.1.1",
          "nodemon": "^3.0.1",
          "supertest": "^6.3.3"
     },
     "jest": {
          "testEnvironment": "node",
          "setupFilesAfterEnv": [
               "<rootDir>/tests/setup.js"
          ],
          "testMatch": [
               "**/__tests__/**/*.js",
               "**/?(*.)+(spec|test).js"
          ]
     }
}