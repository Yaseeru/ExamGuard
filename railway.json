{
     "build": {
          "builder": "NIXPACKS",
          "buildCommand": "cd backend && npm install --production"
     },
     "deploy": {
          "startCommand": "cd backend && npm start",
          "healthcheckPath": "/api/health",
          "healthcheckTimeout": 300,
          "restartPolicyType": "ON_FAILURE",
          "restartPolicyMaxRetries": 10
     }
}